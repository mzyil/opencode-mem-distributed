{
  "name": "opencode-mem",
  "version": "3.0.0-rc.3",
  "description": "OpenCode plugin that gives coding agents persistent memory using local vector database",
  "type": "module",
  "main": "dist/plugin.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/plugin.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/plugin.js",
      "types": "./dist/index.d.ts"
    },
    "./tags": {
      "import": "./dist/services/tags.js",
      "types": "./dist/services/tags.d.ts"
    }
  },
  "bin": {
    "opencode-mem-migrate": "dist/services/storage/migrate-cli.js"
  },
  "scripts": {
    "build": "bunx tsc && mkdir -p dist/web && cp -r src/web/* dist/web/",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,js,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,css,html}\"",
    "lint": "eslint src --max-warnings 0",
    "prepare": "husky",
    "test": "vitest run",
    "test:integration": "RUN_PGVECTOR_TESTS=true vitest run tests/pgvector-scope-filter.test.ts"
  },
  "keywords": [
    "opencode",
    "plugin",
    "memory",
    "vector-database",
    "ai",
    "coding-agent",
    "local",
    "standalone"
  ],
  "author": "opencode-mem",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tickernelz/opencode-mem.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@libsql/client": "^0.17.3",
    "@opencode-ai/plugin": "^1.3.0",
    "@opencode-ai/sdk": "^1.3.0",
    "franc-min": "^6.2.0",
    "iso-639-3": "^3.0.1",
    "kysely": "^0.29.2",
    "kysely-libsql": "^0.7.1",
    "pg": "^8.21.0",
    "usearch": "^2.21.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.0",
    "@types/bun": "^1.3.8",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.7"
  },
  "opencode": {
    "type": "plugin",
    "hooks": [
      "chat.message",
      "event"
    ]
  },
  "files": [
    "dist",
    "package.json"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,jsx,css,html,json,md}": [
      "prettier --write"
    ]
  }
}
